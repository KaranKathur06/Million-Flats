// â”€â”€â”€ Payment System (Razorpay) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

enum PaymentProvider {
  RAZORPAY
  STRIPE
  MANUAL
}

enum PaymentStatus {
  PENDING
  PROCESSING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum PaymentType {
  SUBSCRIPTION
  FEATURED_LISTING
  VERIFICATION
  ADDON
}

model SubscriptionPlanPrice {
  id              String @id @default(uuid())
  plan            AgentSubscriptionPlan
  billingCycle    String @map("billing_cycle") // MONTHLY, ANNUAL
  price           Int @map("price") // in paise (INR * 100)
  currency        String @default("INR")
  razorpayPlanId  String? @map("razorpay_plan_id")
  isActive        Boolean @default(true) @map("is_active")
  features        Json? // JSON object with feature limits
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([plan, billingCycle])
  @@index([isActive])
  @@map("subscription_plan_prices")
}

model Payment {
  id                      String @id @default(uuid())
  agentId                 String @map("agent_id")
  subscriptionId          String? @map("subscription_id")

  // Razorpay identifiers
  razorpayOrderId         String? @unique @map("razorpay_order_id")
  razorpayPaymentId       String? @map("razorpay_payment_id")
  razorpaySignature       String? @map("razorpay_signature")

  // Payment details
  provider                PaymentProvider @default(RAZORPAY)
  status                  PaymentStatus @default(PENDING)
  type                    PaymentType @default(SUBSCRIPTION)

  amount                  Int @map("amount") // in paise
  currency                String @default("INR")
  amountPaid              Int @default(0) @map("amount_paid")
  amountRefunded          Int @default(0) @map("amount_refunded")

  // Subscription details
  plan                    AgentSubscriptionPlan
  billingCycle            String @map("billing_cycle") // MONTHLY, ANNUAL
  subscriptionDays        Int @default(30) @map("subscription_days")

  // Metadata
  notes                   Json? // additional notes from Razorpay
  failureReason           String? @map("failure_reason")
  failureCode             String? @map("failure_code")

  // Timestamps
  paidAt                  DateTime? @map("paid_at")
  refundedAt              DateTime? @map("refunded_at")
  cancelledAt             DateTime? @map("cancelled_at")

  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  agent                   Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  subscription            AgentSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  webhooks                PaymentWebhook[]

  @@index([agentId])
  @@index([status])
  @@index([provider])
  @@index([razorpayPaymentId])
  @@index([createdAt])
  @@map("payments")
}

model PaymentWebhook {
  id                  String @id @default(uuid())
  paymentId           String? @map("payment_id")

  // Webhook data
  razorpayEventId     String? @unique @map("razorpay_event_id")
  eventType           String @map("event_type")
  payload             Json
  signature           String?

  // Processing status
  processed           Boolean @default(false)
  processedAt         DateTime? @map("processed_at")
  processingError     String? @map("processing_error")
  retryCount          Int @default(0) @map("retry_count")

  // Idempotency
  idempotencyKey      String @unique @map("idempotency_key")

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  payment             Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([processed])
  @@index([createdAt])
  @@map("payment_webhooks")
}

// ━━━ AIShield Price Intelligence Engine ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

enum AIShieldStatus {
  FAIR
  OVERPRICED
  UNDERPRICED
  SUSPICIOUS
  INSUFFICIENT_DATA
}

// AIShield platform registry — links projects to the AI Intelligence Platform
model AiShieldProject {
  id                String   @id @default(uuid())
  projectId         String   @unique @map("project_id")
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  isAiEnabled       Boolean  @default(false) @map("is_ai_enabled")
  isAiFeatured      Boolean  @default(false) @map("is_ai_featured")

  // Cached snapshot from AIShield (synced after computation, not duplicated project data)
  aiStatus          AIShieldStatus? @map("ai_status")
  confidenceScore   Float?   @map("confidence_score")
  fairValue         Float?   @map("fair_value")
  lowEstimate       Float?   @map("low_estimate")
  highEstimate      Float?   @map("high_estimate")
  marketSignalScore Float?   @map("market_signal_score")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([isAiEnabled])
  @@index([isAiFeatured])
  @@map("ai_shield_projects")
}

enum MarketListingSource {
  INTERNAL
  SCRAPED
  GOVERNMENT
  PARTNER
}

enum AIShieldPropertyType {
  MANUAL_PROPERTY
  PROJECT
}

model AIShieldResult {
  id                String   @id @default(uuid())

  // Polymorphic: can reference ManualProperty or Project
  entityType        AIShieldPropertyType @map("entity_type")
  entityId          String   @map("entity_id")

  // Valuation
  estimatedMin      Float    @map("estimated_min")
  estimatedMax      Float    @map("estimated_max")
  estimatedMedian   Float    @map("estimated_median")
  confidence        Float    @default(0)    // 0-100
  confidenceReasons Json?    @map("confidence_reasons")

  // Price Analysis
  askingPrice       Float?   @map("asking_price")
  deviation         Float    @default(0)    // percentage
  status            AIShieldStatus @default(FAIR)
  pricePosition     Float?   @map("price_position")  // 0-100 percentile

  // Comparables Summary
  comparablesCount  Int      @default(0) @map("comparables_count")
  avgPricePerSqft   Float?   @map("avg_price_per_sqft")
  medianPrice       Float?   @map("median_price")

  // Market Signals
  demandScore       Float?   @map("demand_score")
  listingVelocity   Float?   @map("listing_velocity")
  avgDaysOnMarket   Float?   @map("avg_days_on_market")

  // Rental Intelligence
  estimatedRentalMin Float?  @map("estimated_rental_min")
  estimatedRentalMax Float?  @map("estimated_rental_max")
  rentalYield        Float?  @map("rental_yield")

  // Negotiation
  suggestedMinPrice  Float?  @map("suggested_min_price")
  suggestedMaxPrice  Float?  @map("suggested_max_price")

  // Metadata
  modelVersion      String   @default("1.0.0") @map("model_version")
  computedAt        DateTime @default(now()) @map("computed_at")
  expiresAt         DateTime @map("expires_at")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([entityType, entityId])
  @@index([entityType, entityId])
  @@index([status])
  @@index([expiresAt])
  @@index([computedAt])
  @@map("AIshield_results")
}

model MarketListing {
  id              String   @id @default(uuid())

  // Location
  city            String
  community       String?
  latitude        Float?
  longitude       Float?
  pincode         String?

  // Property Details
  propertyType    String?  @map("property_type")
  bhk             Int      @default(0)
  sqft            Float    @default(0)
  price           Float
  pricePerSqft    Float?   @map("price_per_sqft")
  currency        String   @default("AED")

  // Listing Info
  source          MarketListingSource @default(INTERNAL)
  sourceUrl       String?  @map("source_url")
  sourceListingId String?  @map("source_listing_id")
  title           String?
  isActive        Boolean  @default(true) @map("is_active")
  listedAt        DateTime @default(now()) @map("listed_at")

  // Amenities & Features
  amenities       Json?
  propertyAge     Int?     @map("property_age")
  floor           Int?
  totalFloors     Int?     @map("total_floors")
  furnished       String?

  // Deduplication
  fingerprint     String?  @unique

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([city, community])
  @@index([city, bhk])
  @@index([city, propertyType])
  @@index([latitude, longitude])
  @@index([source])
  @@index([isActive])
  @@index([price])
  @@index([pricePerSqft])
  @@index([listedAt])
  @@map("market_listings")
}

model PropertyTransaction {
  id              String   @id @default(uuid())

  // Location
  city            String
  community       String?
  latitude        Float?
  longitude       Float?

  // Property Details
  propertyType    String?  @map("property_type")
  bhk             Int      @default(0)
  sqft            Float    @default(0)
  soldPrice       Float    @map("sold_price")
  pricePerSqft    Float?   @map("price_per_sqft")
  currency        String   @default("AED")

  // Transaction
  soldDate        DateTime @map("sold_date")
  source          MarketListingSource @default(INTERNAL)
  sourceRef       String?  @map("source_ref")

  // Optional linked property
  manualPropertyId String? @map("manual_property_id")
  projectId        String? @map("project_id")

  createdAt       DateTime @default(now()) @map("created_at")

  @@index([city, community])
  @@index([city, bhk])
  @@index([soldDate])
  @@index([city, soldDate])
  @@index([manualPropertyId])
  @@index([projectId])
  @@map("property_transactions")
}

model PriceTrend {
  id              String   @id @default(uuid())

  // Location scope
  city            String
  community       String?
  propertyType    String?  @map("property_type")

  // Time period
  month           Int      // 1-12
  year            Int
  periodKey       String   @map("period_key")  // "2026-04"

  // Metrics
  avgPricePerSqft Float    @map("avg_price_per_sqft")
  medianPrice     Float    @map("median_price")
  totalListings   Int      @default(0) @map("total_listings")
  totalTransactions Int    @default(0) @map("total_transactions")
  priceChangePercent Float? @map("price_change_percent")  // vs previous month

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([city, community, propertyType, periodKey])
  @@index([city, community])
  @@index([periodKey])
  @@index([year, month])
  @@map("price_trends")
}

model MarketSignal {
  id              String   @id @default(uuid())

  // Location scope
  city            String
  community       String?

  // Signals
  demandScore     Float    @default(50) @map("demand_score")     // 0-100
  supplyScore     Float    @default(50) @map("supply_score")     // 0-100
  listingVelocity Float    @default(0)  @map("listing_velocity") // new listings/week
  avgDaysOnMarket Float    @default(0)  @map("avg_days_on_market")
  inventoryMonths Float?   @map("inventory_months")
  priceToRentRatio Float?  @map("price_to_rent_ratio")

  // Metadata
  calculatedAt    DateTime @default(now()) @map("calculated_at")
  dataPointCount  Int      @default(0) @map("data_point_count")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([city, community])
  @@index([city])
  @@index([calculatedAt])
  @@map("market_signals")
}

model AIShieldAuditLog {
  id              String   @id @default(uuid())

  entityType      AIShieldPropertyType @map("entity_type")
  entityId        String   @map("entity_id")

  // Computation details
  trigger         String   @default("api_request")  // api_request, scheduled, manual
  durationMs      Int      @map("duration_ms")       // computation time
  servicesUsed    Json?    @map("services_used")     // which engines ran
  inputSnapshot   Json?    @map("input_snapshot")    // property data used
  resultSnapshot  Json?    @map("result_snapshot")   // final output

  // Error tracking
  hadErrors       Boolean  @default(false) @map("had_errors")
  errors          Json?

  createdAt       DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([hadErrors])
  @@map("AIshield_audit_logs")
}

// ━━━ AIShield v2.1 — Intelligence Engine Extensions ━━━━━━━━━━━━━━━━━━━

// Feedback loop: captures actual sold prices to calibrate model accuracy
model ValuationFeedback {
  id              String   @id @default(uuid())

  entityType      AIShieldPropertyType @map("entity_type")
  entityId        String   @map("entity_id")

  // What the model predicted
  predictedLow    Float?   @map("predicted_low")
  predictedFair   Float?   @map("predicted_fair")
  predictedHigh   Float?   @map("predicted_high")
  confidence      Float?

  // What actually happened
  actualPrice     Float    @map("actual_price")
  actualPriceDate DateTime @map("actual_price_date")
  errorPercentage Float?   @map("error_percentage")
  source          String   @default("ADMIN_INPUT")

  // Context
  city            String?
  community       String?
  modelVersion    String?  @map("model_version")

  createdAt       DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([city, community])
  @@index([errorPercentage])
  @@index([createdAt])
  @@index([modelVersion])
  @@map("valuation_feedback")
}

// Per-locality data quality scoring
model DataQualityMetric {
  id              String   @id @default(uuid())

  city            String
  community       String?

  score           Float    @default(50)
  status          String   @default("MEDIUM")
  txDensityScore  Float    @default(0) @map("tx_density_score")
  listingDensityScore Float @default(0) @map("listing_density_score")
  recencyScore    Float    @default(0) @map("recency_score")
  sourceDiversityScore Float @default(0) @map("source_diversity_score")

  calculatedAt    DateTime @default(now()) @map("calculated_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([city, community])
  @@index([score])
  @@index([calculatedAt])
  @@map("data_quality_metrics")
}

// Track model accuracy per location over time
model ModelPerformanceLog {
  id              String   @id @default(uuid())

  locationKey     String   @map("location_key")
  city            String?
  community       String?
  modelVersion    String   @map("model_version")
  segment         String?

  mape            Float    @default(0)
  mae             Float?
  r2Score         Float?   @map("r2_score")
  sampleSize      Int      @default(0) @map("sample_size")

  calculatedAt    DateTime @default(now()) @map("calculated_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([locationKey, modelVersion])
  @@index([modelVersion])
  @@index([mape])
  @@index([calculatedAt])
  @@map("model_performance_logs")
}

// Snapshot of market volatility per area
model MarketVolatilitySnapshot {
  id              String   @id @default(uuid())

  city            String
  community       String?

  mviIndex        Float    @default(1.0) @map("mvi_index")
  classification  String   @default("NORMAL")
  priceVarianceTrend Float @map("price_variance_trend")
  demandFluctuation Float  @map("demand_fluctuation")
  txVelocityChange Float   @map("tx_velocity_change")
  effectiveThreshold Float @map("effective_threshold")

  calculatedAt    DateTime @default(now()) @map("calculated_at")

  @@index([city, community])
  @@index([calculatedAt])
  @@map("market_volatility_snapshots")
}

// ━━━ Secure Asset Delivery — Access Audit Log ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model AssetAccessLog {
