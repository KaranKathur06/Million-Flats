// ─── Developer Projects System ───────────────────────────────────────

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Project {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique

  developerId     String   @map("developer_id") @db.Text
  developer       Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  countryIso2     String?  @db.Char(2) @map("country_iso2")
  city            String?
  community       String?

  description     String?  @db.Text
  highlights      String?  @db.Text @map("highlights_json")

  completionYear  Int?     @map("completion_year")
  startingPrice   Float?   @map("starting_price")

  goldenVisa      Boolean  @default(false) @map("golden_visa")

  coverImage      String?  @map("cover_image")

  status          ProjectStatus @default(DRAFT)

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  media           ProjectMedia[]
  unitTypes       ProjectUnitType[]
  leads           ProjectLead[]
  amenities       ProjectAmenity[]
  paymentPlans    ProjectPaymentPlan[]
  floorPlans      ProjectFloorPlan[]
  videos          ProjectVideo[]
  location        ProjectLocation?
  nearbyPlaces    ProjectNearbyPlace[]

  @@index([developerId])
  @@index([status])
  @@index([city])
  @@index([goldenVisa])
  @@index([name])
  @@index([countryIso2, city])
  @@map("projects")
}

model ProjectMedia {
  id        String   @id @default(uuid())

  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  mediaUrl  String   @map("media_url")
  mediaType String   @map("media_type")
  s3Key     String?  @map("s3_key")
  sortOrder Int?     @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@map("project_media")
}

model ProjectUnitType {
