  unitType  String   @map("unit_type")
  sizeFrom  Int?     @map("size_from")
  sizeTo    Int?     @map("size_to")

  priceFrom Float?   @map("price_from")

  @@index([projectId])
  @@map("project_unit_types")
}

model ProjectLead {
