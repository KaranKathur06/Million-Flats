datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  BUYER
  AGENT
  DEVELOPER
  AGENCY
  MODERATOR
  VERIFIER
  ADMIN
  SUPERADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum AgentStatus {
  REGISTERED
  EMAIL_VERIFIED
  PROFILE_INCOMPLETE
  PROFILE_COMPLETED
  DOCUMENTS_UPLOADED
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum AgentSubscriptionPlan {
  BASIC
  PROFESSIONAL
  PREMIUM
}

enum AgentSubscriptionStatus {
  TRIAL
  ACTIVE
  CANCELLED
  EXPIRED
}

enum AgentPropertyType {
  RESIDENTIAL
  LUXURY
  COMMERCIAL
}

enum AgentServiceType {
  BUY
  SELL
  RENT
}

enum AgentVerificationDocumentType {
  LICENSE
  ID
  PAN
  AADHAR
  PASSPORT
  RERA_CERTIFICATE
  BROKER_LICENSE
  GST_CERTIFICATE
  SELFIE_ID
  GOVERNMENT_ID
  REAL_ESTATE_LICENSE
  SELFIE_VERIFICATION
  ADDRESS_PROOF
  AGENCY_CERTIFICATE
}

enum AgentVerificationStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  FLAGGED
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AgentProfileStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  LIVE
  SUSPENDED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

enum UserRole {
  ADMIN
  EDITOR
  AUTHOR
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   @db.Text
  contentJson Json?
  contentHtml String?  @db.Text @map("content_html")
  featuredImageUrl String?
  featuredImageAlt String?
  targetKeyword String
  metaTitle   String
  metaDescription String
  canonicalUrl String?
  status      BlogStatus @default(DRAFT)
  publishAt   DateTime?
  authorId    String
  categoryId  String
  seoScore    Int
  readTimeMinutes Int
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tags        BlogTag[]

  @@index([status])
  @@index([publishAt])
  @@index([createdAt])
  @@index([status, publishAt, createdAt])
  @@index([authorId])
  @@index([categoryId])
  @@index([slug])
  @@index([views])
  @@index([seoScore])
  @@map("blogs")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")
  blogs       Blog[]

  @@map("categories")
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  blogTags  BlogTag[]

  @@map("tags")
}

model BlogTag {
  blogId String
  tagId  String

  blog Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
  @@map("blog_tags")
}

model User {
  id        String   @id @default(uuid())
  role      Role     @default(USER)
  status    UserStatus @default(ACTIVE)
  name      String?
  email     String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")
  emailVerifiedByAdminId String? @map("email_verified_by_admin_id")
  image     String?
  password  String?  @map("password_hash")
  googleId  String?   @unique @map("google_id")
  phone     String?
  phoneCountryIso2   String?  @db.Char(2) @map("phone_country_iso2")
  phoneNationalNumber String? @map("phone_national_number")

  phoneCountry Country? @relation("UserPhoneCountry", fields: [phoneCountryIso2], references: [iso2])

  countryIso2 String? @db.Char(2) @map("country_iso2")
  country     Country? @relation(fields: [countryIso2], references: [iso2])
  verified  Boolean  @default(false) @map("is_verified")

  buyer Buyer?
  agent Agent?
  developerProfile DeveloperProfile?
  agencyProfile    AgencyProfile?

  accounts Account[]
  sessions Session[]

  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]

  savedProperties SavedProperty[]
  propertyLeads   PropertyLead[]
  preference      UserPreference?

  manualPropertyModerationLogs ManualPropertyModerationLog[] @relation("ManualPropertyModerationAdmin")
  auditLogs AuditLog[] @relation("AuditLogPerformedBy")
  moderationCases ModerationCase[] @relation("ModerationCaseCreatedBy")
  moderationActions ModerationAction[] @relation("ModerationActionActor")
  moderationMessages ModerationMessage[] @relation("ModerationMessageActor")
  reportsSubmitted Report[] @relation("ReportSubmittedBy")
  inquiries Inquiry[]
  leadMagnetDownloads LeadMagnetDownload[]
  brochureDownloads BrochureDownload[]

  blogs Blog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  preferredLanguage String?   @map("preferred_language")
  authProvider      String?   @map("auth_provider")
  lastDevice        String?   @map("last_device")
  lastIp            String?   @map("last_ip")
  lastLogin         DateTime? @map("last_login")
  profileCompletion Int       @default(0) @map("profile_completion")

  // Onboarding Fields
  city                  String?
  occupation            String?
  ageGroup              String?   @map("age_group")
  purpose               String?
  interestedCountry     String?   @map("interested_country")
  budgetMin             Float?    @map("budget_min")
  budgetMax             Float?    @map("budget_max")
  propertyTypes         String[]  @map("property_types")
  bedrooms              String[]
  preferredCities       String[]  @map("preferred_cities")
  preferredLocalities   String[]  @map("preferred_localities")
  buyingTimeline        String?   @map("buying_timeline")
  investmentGoal        String?   @map("investment_goal")
  servicesInterested    String[]  @map("services_interested")
  communicationPrefs    String[]  @map("communication_prefs")
  marketingConsent      Boolean   @default(true) @map("marketing_consent")
  profileCompletedAt    DateTime? @map("profile_completed_at")
  onboardingVersion     Int       @default(0) @map("onboarding_version")
  currentOnboardingStep Int       @default(1) @map("current_onboarding_step")

  @@map("users")
}

enum CountryCode {
  UAE
  INDIA
}

model Country {
  iso2      String   @id @db.Char(2)
  iso3      String   @db.Char(3)
  name      String
  dialCode  String   @map("dial_code")
  region    String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       User[]
  userPhones  User[]   @relation("UserPhoneCountry")
  agents      Agent[]
  agencies    Agency[]
  developers  Developer[]
  properties  ManualProperty[]
  featuredAgentClicks FeaturedAgentClick[]

  @@index([isActive])
  @@index([region])
  @@map("countries")
}

enum PropertySourceType {
  REELLY
  MANUAL
}

enum ManualPropertyStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SOLD
  ARCHIVED
}

enum ManualPropertyMediaCategory {
  COVER
  EXTERIOR
  INTERIOR
  FLOOR_PLANS
  AMENITIES
  BROCHURE
  VIDEO
}

enum ManualPropertyIntent {
  SALE
  RENT
}

enum ManualPropertyConstructionStatus {
  READY
  OFF_PLAN
}

enum ManualModerationAction {
  APPROVE
  REJECT
}

enum InquiryStatus {
  PENDING
  RESPONDED
  NEW
  CONTACTED
  VISIT_SCHEDULED
  NEGOTIATION
  CLOSED
  LOST
}

 enum ModerationEntityType {
   MANUAL_PROPERTY
   AGENT
   USER
   ECOSYSTEM_PARTNER
   ECOSYSTEM_PARTNER_APPLICATION
 }

 enum ModerationCaseStatus {
   OPEN
   CLOSED
 }

 enum ModerationQueue {
   NORMAL
   HIGH_RISK
 }

 enum ModerationDecision {
   APPROVED
   REJECTED
   FLAGGED
   ESCALATED
   REQUEST_INFO
 }

 enum ReportStatus {
   OPEN
   REVIEWED
   CLOSED
 }


model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@map("password_reset_tokens")
}

model LoginOtp {
  id        String   @id @default(uuid())
  email     String
  role      String
  codeHash  String   @map("code_hash")
  attempts  Int      @default(0)
  expiresAt DateTime @map("expires_at")
  consumed  Boolean  @default(false)
  loginTokenHash String? @map("login_token_hash")
  loginTokenExpiresAt DateTime? @map("login_token_expires_at")
  usedAt    DateTime? @map("used_at")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([role])
  @@index([expiresAt])
  @@index([consumed])
  @@index([loginTokenExpiresAt])
  @@index([usedAt])
  @@map("login_otps")
}

model Agent {
  id       String  @id @default(uuid())
  userId   String  @unique @map("user_id")
  agencyId String? @map("agency_id")
  company  String? @map("company_name")
  license  String? @unique @map("license_number")
  licenseAuthority String? @map("license_authority")
  yearsExperience Int? @map("years_experience")
  primaryMarket String? @map("primary_market")
  specialization String[] @default([]) @map("specialization")
  linkedinUrl String? @map("linkedin_url")
  websiteUrl String? @map("website_url")
  isFeaturedManual Boolean @default(false) @map("is_featured_manual")
  featuredScore Int @default(0) @map("featured_score")
  totalListings Int @default(0) @map("total_listings")
  totalLeads Int @default(0) @map("total_leads")
  respondedLeads Int @default(0) @map("responded_leads")
  responseRate Float @default(0) @map("response_rate")
  whatsapp String? @map("whatsapp_number")
  countryCode CountryCode @default(UAE) @map("country")
  countryIso2 String? @db.Char(2) @map("country_iso2")
  country     Country? @relation(fields: [countryIso2], references: [iso2])
  isFeatured Boolean @default(false) @map("is_featured")
  profilePhoto String? @map("profile_photo")
  profileImageUrl String? @map("profile_image_url")
  profileImageKey String? @map("profile_image_key")
  profileImageUpdatedAt DateTime? @map("profile_image_updated_at")
  approved Boolean @default(false)
  profileStatus AgentProfileStatus? @map("profile_status")
  verificationStatus AgentVerificationStatus? @map("verification_status")

  status AgentStatus @default(REGISTERED) @map("status")

  bio String? @db.Text
  profileCompletion Int @default(0) @map("profile_completion")
  profileCompletionUpdatedAt DateTime? @map("profile_completion_updated_at")

  riskScore         Int @default(0) @map("risk_score")
  approvedBy        String? @map("approved_by")
  approvedAt        DateTime? @map("approved_at")
  rejectionReason   String? @db.Text @map("rejection_reason")

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency Agency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  leads PropertyLead[]
  listings AgentListing[]
  manualProperties ManualProperty[]

  serviceAreas AgentServiceArea[]
  specializations AgentSpecialization[]
  metrics AgentMetric?
  badges AgentBadge[]
  verifications AgentVerification[]
  reviews AgentReview[]
  featuredClicks FeaturedAgentClick[]
  inquiries Inquiry[]
  documents AgentDocument[]
  verificationProgress AgentVerificationProgress?

  subscription AgentSubscription?
  payments     Payment[]
  aiIntelligence AgentAIIntelligence?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([countryCode, isFeatured])
  @@index([countryIso2, isFeatured])
  @@index([countryIso2, featuredScore])
  @@index([agencyId])
  @@index([status])
  @@index([riskScore])
  @@map("agents")
}

model AgentSubscription {
  id        String @id @default(uuid())
  agentId   String @unique @map("agent_id")

  plan      AgentSubscriptionPlan @default(BASIC)
  status    AgentSubscriptionStatus @default(TRIAL)

  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  trialEndsAt DateTime? @map("trial_ends_at")
  cancelledAt DateTime? @map("cancelled_at")

  listingsLimit Int? @map("listings_limit")
  featuredLimit Int? @map("featured_limit")
  leadLimit     Int? @map("lead_limit")
  leadPriority  String? @map("lead_priority")
  AIAccessLevel Int? @map("AI_access_level")

  provider String? @map("provider")
  providerSubscriptionId String? @map("provider_subscription_id")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  payments Payment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([plan])
  @@map("agent_subscriptions")
}

model FeaturedAgentClick {
  id String @id @default(uuid())
  agentId String @map("agent_id")
  countryIso2 String? @db.Char(2) @map("country_iso2")
  clickedAt DateTime @default(now()) @map("clicked_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  country Country? @relation(fields: [countryIso2], references: [iso2], onDelete: SetNull)

  @@index([agentId])
  @@index([countryIso2])
  @@index([clickedAt])
  @@map("featured_agent_clicks")
}

model Agency {
  id String @id @default(uuid())
  name String
  countryCode CountryCode @default(UAE) @map("country")
  countryIso2 String? @db.Char(2) @map("country_iso2")
  country     Country? @relation(fields: [countryIso2], references: [iso2])
  isFeatured Boolean @default(false) @map("is_featured")

  agents Agent[]
  agencyProfiles AgencyProfile[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([countryCode, isFeatured])
  @@index([countryIso2, isFeatured])
  @@map("agencies")
}


enum DeveloperStatus {
  ACTIVE
  INACTIVE
}

model Developer {
  id String @id @default(dbgenerated("gen_random_uuid()::text")) @db.Text
  name String @unique
  slug String? @unique
  logo String?
  banner String?              @db.Text
  countryCode CountryCode @default(UAE) @map("country")
  countryIso2 String? @db.Char(2) @map("country_iso2")
  country     Country? @relation(fields: [countryIso2], references: [iso2])
  city        String?
  description String?          @db.Text
  shortDescription String?     @map("short_description")
  website     String?
  foundedYear Int?             @map("founded_year")
  headquarters String?
  email       String?
  phone       String?
  address     String?          @db.Text

  // Social links
  facebookUrl  String?         @map("facebook_url")
  instagramUrl String?         @map("instagram_url")
  linkedinUrl  String?         @map("linkedin_url")
  youtubeUrl   String?         @map("youtube_url")

  // Trust & rating
  customerRating    Float?     @map("customer_rating")
  projectsDelivered Int?       @map("projects_delivered")
  countriesPresent  Int?       @map("countries_present")
  AIScore        Int?       @map("AI_score")

  // SEO fields
  metaTitle       String?      @map("meta_title")
  metaDescription String?      @map("meta_description") @db.Text
  metaKeywords    String?      @map("meta_keywords")
  ogImage         String?      @map("og_image")
  canonicalUrl    String?      @map("canonical_url")

  // Brochure
  brochureUrl     String?      @map("developer_brochure_url")

  isFeatured Boolean @default(false) @map("is_featured")
  featuredRank Int?            @map("featured_rank")
  status      DeveloperStatus @default(ACTIVE)
  isDeleted   Boolean  @default(false) @map("is_deleted")
  deletedAt   DateTime?        @map("deleted_at")

  properties ManualProperty[]
  projects   Project[]
  achievements DeveloperAchievement[]
  faqs         DeveloperFaq[]
  gallery      DeveloperGallery[]
  leads        Lead[]
  userProfiles DeveloperProfile[] // Authenticated developer users linked to this company

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([countryCode, isFeatured])
  @@index([countryIso2, isFeatured])
  @@index([status])
  @@index([slug])
  @@index([isDeleted])
  @@map("developers")
}

model DeveloperAchievement {
  id           String    @id @default(uuid())
  developerId  String    @map("developer_id") @db.Text
  developer    Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
  title        String
  description  String?   @db.Text
  imageUrl     String?   @map("image_url")
  awardDate    DateTime? @map("award_date")
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([developerId])
  @@map("developer_achievements")
}

model DeveloperFaq {
  id           String    @id @default(uuid())
  developerId  String    @map("developer_id") @db.Text
  developer    Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
  question     String
  answer       String    @db.Text
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([developerId])
  @@map("developer_faqs")
}

model DeveloperGallery {
  id           String    @id @default(uuid())
  developerId  String    @map("developer_id") @db.Text
  developer    Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
  imageUrl     String    @map("image_url")
  caption      String?
  category     String?
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([developerId])
  @@map("developer_gallery")
}

model AgentServiceArea {
  id       String @id @default(uuid())
  agentId  String @map("agent_id")
  city     String
  locality String?
  latitude Float?
  longitude Float?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([agentId])
  @@index([city])
  @@unique([agentId, city, locality])
  @@map("agent_service_areas")
}

model AgentSpecialization {
  id           String @id @default(uuid())
  agentId      String @map("agent_id")
  propertyType AgentPropertyType @map("property_type")
  serviceType  AgentServiceType @map("service_type")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([agentId])
  @@index([propertyType])
  @@index([serviceType])
  @@unique([agentId, propertyType, serviceType])
  @@map("agent_specializations")
}

model AgentMetric {
  id               String @id @default(uuid())
  agentId          String @unique @map("agent_id")
  dealsClosed      Int @default(0) @map("deals_closed")
  avgTimeToCloseDays Int? @map("avg_time_to_close_days")
  saleToListRatio  Float? @map("sale_to_list_ratio")
  responseRate     Float? @map("response_rate")
  repeatClientRate Float? @map("repeat_client_rate")
  AIproScore    Int @default(0) @map("AIpro_score")
  lastCalculatedAt DateTime? @map("last_calculated_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([AIproScore])
  @@map("agent_metrics")
}

model AgentBadge {
  id       String @id @default(uuid())
  agentId  String @map("agent_id")
  badgeKey String @map("badge_key")
  earnedAt DateTime @default(now()) @map("earned_at")
  revokedAt DateTime? @map("revoked_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([badgeKey])
  @@unique([agentId, badgeKey])
  @@map("agent_badges")
}

model AgentVerification {
  id           String @id @default(uuid())
  agentId      String @map("agent_id")
  documentType AgentVerificationDocumentType @map("document_type")
  documentUrl  String @map("document_url")
  status       AgentVerificationStatus @default(PENDING)
  reviewedAt   DateTime? @map("reviewed_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([agentId])
  @@index([status])
  @@index([documentType])
  @@map("agent_verifications")
}

model AgentReview {
  id            String @id @default(uuid())
  agentId       String @map("agent_id")
  rating        Int
  comment       String? @db.Text
  verifiedDealId String? @map("verified_deal_id")
  createdAt     DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([rating])
  @@map("agent_reviews")
}

model ManualProperty {
  id          String @id @default(uuid())
  agentId     String @map("agent_id")
  developerId String? @map("developer_id") @db.Text
  sourceType  PropertySourceType @default(MANUAL) @map("source_type")
  status      ManualPropertyStatus @default(DRAFT)

  lastCompletedStep String? @map("last_completed_step")

  clonedFromId String? @map("cloned_from_id")
  clonedFrom ManualProperty? @relation("ManualPropertyClone", fields: [clonedFromId], references: [id], onDelete: SetNull)
  clones ManualProperty[] @relation("ManualPropertyClone")

  archivedAt DateTime? @map("archived_at")
  archivedBy String? @map("archived_by")

  title       String?
  propertyType String? @map("property_type")
  intent      ManualPropertyIntent?
  price       Float?
  currency    String @default("AED")
  constructionStatus ManualPropertyConstructionStatus? @map("construction_status")
  shortDescription String? @map("short_description")

  bedrooms   Int @default(0)
