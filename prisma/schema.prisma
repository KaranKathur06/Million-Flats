model EcosystemPartner {
  id               String  @id @default(cuid())
  categoryId       String
  name             String
  logo             String?
  shortDescription String?
  rating           Float?
  yearsExperience  Int?
  locationCoverage String?
  contactEmail     String?
  contactPhone     String?
  whatsapp         String?
  website          String?
  coverImage       String?
  description      String?
  contactPerson    String?
  serviceAreas     Json?
  gstNumber        String?
  registrationNumber String?
  pricingRange     String?
  categoryData     Json?

  status           EcosystemPartnerStatus @default(PENDING)
  isFeatured       Boolean @default(false)
  isVerified       Boolean @default(false)
  subscriptionTier EcosystemSubscriptionTier @default(FREE)
  priorityOrder    Int     @default(0)
  isActive         Boolean @default(true)

  category EcosystemCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  leads    EcosystemLead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([priorityOrder])
  @@index([isFeatured])
  @@index([isVerified])
  @@index([status])
  @@index([subscriptionTier])
  @@index([isActive])
  @@unique([categoryId, contactEmail])
}

