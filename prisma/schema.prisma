   actorUserId String? @map("actor_user_id")
   message   String @db.Text

   moderationCase ModerationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
   actorUser User? @relation("ModerationMessageActor", fields: [actorUserId], references: [id], onDelete: SetNull)

   createdAt DateTime @default(now()) @map("created_at")

   @@index([caseId])
   @@index([actorUserId])
   @@index([createdAt])
   @@map("moderation_messages")
 }

 model Report {
   id        String @id @default(uuid())
   caseId    String @map("case_id")
