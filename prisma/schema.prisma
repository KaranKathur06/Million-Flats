 model ModerationCase {
   id         String @id @default(uuid())
   entityType ModerationEntityType @map("entity_type")
   entityId   String @map("entity_id")
   status     ModerationCaseStatus @default(OPEN)
   queue      ModerationQueue @default(NORMAL)

   currentRiskScore Int @default(0) @map("current_risk_score")
   currentRiskReasons Json? @map("current_risk_reasons")
   currentRiskEngineVersion String @default("1.0.0") @map("current_risk_engine_version")
