model Project {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique

  developerId     String   @map("developer_id") @db.Text
  developer       Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  countryIso2     String?  @db.Char(2) @map("country_iso2")
  city            String?
  community       String?

  description     String?  @db.Text
  overview        String?  @db.Text
  highlights      String?  @db.Text @map("highlights_json")

  completionYear  Int?     @map("completion_year")
  startingPrice   Float?   @map("starting_price")

  goldenVisa      Boolean  @default(false) @map("golden_visa")

  coverImage      String?  @map("cover_image")
  brochureUrl     String?  @map("brochure_url")
  videoUrl        String?  @map("video_url")
  virtualTourUrl  String?  @map("virtual_tour_url")
  possessionDate  DateTime? @map("possession_date")
  paymentPlan     Json?    @map("payment_plan")
  isFeatured      Boolean  @default(false) @map("is_featured")
  featuredOrder   Int?     @map("featured_order")

  status          ProjectStatus @default(DRAFT)
  isDeleted       Boolean  @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at")
  deletedBy       String? @map("deleted_by")
  archivedAt      DateTime? @map("archived_at")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  media           ProjectMedia[]
  unitTypes       ProjectUnitType[]
  unitVariants    ProjectUnitVariant[]
  leads           ProjectLead[]
  amenities       ProjectAmenity[]
  paymentPlans    ProjectPaymentPlan[]
  floorPlans      ProjectFloorPlan[]
  videos          ProjectVideo[]
  location        ProjectLocation?
  nearbyPlaces    ProjectNearbyPlace[]
  brochure        ProjectBrochure?
  brochureDownloads BrochureDownload[]

  @@index([developerId])
  @@index([status])
  @@index([isDeleted])
  @@index([archivedAt])
  @@index([city])
  @@index([goldenVisa])
  @@index([isFeatured, featuredOrder])
  @@index([name])
  @@index([countryIso2, city])
  @@map("projects")
}

